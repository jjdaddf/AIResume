# 阿里云通义千问 API
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Qdrant 向量数据库（可选，不配置则使用降级模式）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_RESUME=resume_vectors
QDRANT_COLLECTION_SKILLS=skill_vectors
QDRANT_COLLECTION_JD=jd_vectors

# 文档导出
EXPORT_DIR=./exports

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MySQL 数据库（可选，不配置则使用本地 SQLite 模式）
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=airesume
